@model SistemaBiblioteca.Models.Editorial

@{
    ViewData["Title"] = "Nueva Editorial";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow">
 <div class="card-header bg-color2 text-white">
   <h3 class="mb-0">
     <i class="fas fa-plus"></i> Nueva Editorial
  </h3>
        </div>
    <div class="card-body p-4">
 <form asp-action="Create" method="post">
   @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

     <div class="mb-3">
  <label asp-for="NombreEditorial" class="form-label fw-semibold color2">Nombre de la Editorial *</label>
 <input asp-for="NombreEditorial" class="form-control form-control-lg"
      placeholder="Ej: Editorial Planeta, Penguin Random House..." required>
  <span asp-validation-for="NombreEditorial" class="text-danger small"></span>
   </div>

  <div class="d-grid gap-2">
        <button type="submit" class="btn btn-primary btn-lg">
   <i class="fas fa-save"></i> Crear Editorial
</button>
      <a asp-action="Index" class="btn btn-outline-secondary">
 <i class="fas fa-times"></i> Cancelar
    </a>
   </div>
 </form>
      </div>
      </div>
  </div>
</div>

@section Scripts {
@{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
