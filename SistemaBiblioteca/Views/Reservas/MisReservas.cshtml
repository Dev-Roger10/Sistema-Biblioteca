@model IEnumerable<SistemaBiblioteca.Models.Reserva>

@{
    ViewData["Title"] = "Mis Reservas";
}

<div class="row mb-4">
    <div class="col-12 text-center">
        <h2 class="fw-bold color1">
            <i class="fas fa-bookmark color2"></i> Mis Reservas
        </h2>
        <p class="color2">Gestiona tus reservas de libros</p>
    </div>
</div>

<!-- Alerta de límite -->
<div class="alert alert-info border-0 shadow-sm" style="background: linear-gradient(135deg, rgba(8,137,255,0.1) 0%, rgba(8,207,255,0.1) 100%); border-left: 4px solid var(--color-2);">
    <i class="fas fa-info-circle color2"></i>
    Tienes <strong class="color1">@ViewBag.ReservasPendientes</strong> reservas activas.
    Límite: <strong class="color1">@ViewBag.LimiteReservas</strong> reservas simultáneas.
</div>

<!-- Lista de Reservas -->
<div class="row g-4">
    @foreach (var reserva in Model)
    {
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="badge bg-@(reserva.TipoReserva == "Local" ? "primary" : "info")">
                            @reserva.TipoReserva
                        </span>
                        @switch (reserva.EstadoReserva)
                        {
                            case "Pendiente":
                                <span class="badge bg-warning">Pendiente</span>
                                break;
                            case "Confirmada":
                                <span class="badge bg-success">Confirmada</span>
                                break;
                            case "Cancelada":
                                <span class="badge bg-danger">Cancelada</span>
                                break;
                            case "Vencida":
                                <span class="badge bg-secondary">Vencida</span>
                                break;
                        }
                    </div>

                    <div class="d-flex mb-3">
                        <img src="@(reserva.Libro.ImagenPortada ?? "/images/libro-default.jpg")"
                             class="rounded me-3" style="width: 70px; height: 95px; object-fit: cover;">
                        <div>
                            <h5 class="fw-bold color1 mb-1">@reserva.Libro.Titulo</h5>
                            <p class="color2 mb-1">
                                <i class="fas fa-user"></i> @reserva.Libro.Autor
                            </p>
                            <p class="color2 mb-0">
                                <i class="fas fa-tag"></i> @(reserva.Libro.Categoria?.NombreCategoria ?? "N/A")
                            </p>
                        </div>
                    </div>

                    <hr>

                    <div class="row text-center mb-3">
                        <div class="col-6">
                            <small class="color2 d-block">Fecha Reserva</small>
                            <strong class="color1">@reserva.FechaReserva.ToString("dd/MM/yyyy")</strong>
                        </div>
                        <div class="col-6">
                            <small class="color2 d-block">Vence</small>
                            <strong class="color1">@reserva.FechaVencimiento?.ToString("dd/MM/yyyy")</strong>
                        </div>
                    </div>

                    @if (reserva.EstadoReserva == "Pendiente")
                    {
                        <form asp-controller="Reservas" asp-action="Cancelar" method="post"
                              onsubmit="return confirm('¿Desea cancelar esta reserva?');">
                            <input type="hidden" name="id" value="@reserva.IdReserva" />
                            <input type="hidden" name="motivo" value="Cancelado por el usuario" />
                            <button type="submit" class="btn btn-danger btn-sm w-100">
                                <i class="fas fa-times"></i> Cancelar Reserva
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <i class="fas fa-bookmark fa-5x text-muted mb-3"></i>
            <h4 class="text-muted">No tienes reservas</h4>
            <p class="text-muted">Busca un libro y haz tu primera reserva</p>
            <a asp-controller="Libros" asp-action="Catalogo" class="btn btn-primary mt-3">
                <i class="fas fa-search"></i> Ir al Catálogo
            </a>
        </div>
    }
</div>