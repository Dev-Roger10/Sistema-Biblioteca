@{
    ViewData["Title"] = "Registrar Nuevo Prťstamo";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow">
     <div class="card-header bg-color2 text-white">
          <h3 class="mb-0">
  <i class="fas fa-hand-holding-book"></i> Registrar Nuevo Prťstamo
      </h3>
   </div>
     <div class="card-body p-4">
          <form asp-action="Create" method="post">
   @Html.AntiForgeryToken()

              <div class="alert alert-info">
    <i class="fas fa-info-circle"></i>
     <strong>Nota:</strong> Seleccione un usuario, un ejemplar disponible y registre el prťstamo.
           </div>

        <!-- Informaciůn de Prťstamo -->
    <h5 class="color1 mb-3">
<i class="fas fa-user color2"></i> Informaciůn del Prťstamo
          </h5>

         @if (ViewBag.ReservaSeleccionada != null)
           {
           <div class="alert alert-success border-0">
         <i class="fas fa-check-circle"></i>
      <strong>Prťstamo desde Reserva:</strong> @ViewBag.ReservaSeleccionada.Libro.Titulo
            </div>
        <input type="hidden" name="idReserva" value="@ViewBag.ReservaSeleccionada.IdReserva" />
      <input type="hidden" name="idUsuario" value="@ViewBag.ReservaSeleccionada.IdUsuario" />

<div class="mb-3">
   <label class="form-label fw-semibold color2">Usuario</label>
 <input type="text" class="form-control" value="@ViewBag.ReservaSeleccionada.Usuario.NombreCompleto" disabled>
            </div>

           <div class="mb-3">
         <label class="form-label fw-semibold color2">Libro</label>
   <input type="text" class="form-control" value="@ViewBag.ReservaSeleccionada.Libro.Titulo" disabled>
            </div>

      <div class="mb-3">
          <label class="form-label fw-semibold color2">Ejemplar *</label>
            <select name="idEjemplar" class="form-select" required>
             <option value="">-- Seleccione un ejemplar --</option>
      @foreach (var ej in ViewBag.EjemplaresDisponibles as List<SistemaBiblioteca.Models.Ejemplar>)
               {
           <option value="@ej.IdEjemplar">
  Cůdigo: @ej.CodigoEjemplar - Sede: @ej.Sede?.NombreSede
     </option>
         }
    </select>
       </div>
        }
        else
           {
           <div class="row g-3 mb-3">
          <div class="col-md-6">
           <label class="form-label fw-semibold color2">Usuario *</label>
   <select name="idUsuario" class="form-select" required>
      <option value="">-- Seleccione usuario --</option>
   @foreach (var usuario in ViewBag.Usuarios as List<SistemaBiblioteca.Models.Usuario>)
           {
  <option value="@usuario.IdUsuario">
        @usuario.NombreCompleto - @usuario.Rol?.NombreRol
       </option>
}
       </select>
          </div>
         <div class="col-md-6">
   <label class="form-label fw-semibold color2">Ejemplar *</label>
              <select name="idEjemplar" class="form-select" required>
           <option value="">-- Seleccione ejemplar --</option>
        @foreach (var ej in ViewBag.EjemplaresDisponibles as List<SistemaBiblioteca.Models.Ejemplar> ?? new List<SistemaBiblioteca.Models.Ejemplar>())
        {
 <option value="@ej.IdEjemplar">
     @ej.Libro?.Titulo - Cůdigo: @ej.CodigoEjemplar
           </option>
     }
</select>
       </div>
           </div>
   }

          <div class="mb-3">
      <label class="form-label fw-semibold color2">Observaciones</label>
     <textarea name="observaciones" class="form-control" rows="3" placeholder="Notas adicionales del prťstamo..."></textarea>
      </div>

        <hr class="my-4">

           <!-- Informaciůn Adicional -->
               <h5 class="color1 mb-3">
          <i class="fas fa-calendar-alt color2"></i> Informaciůn de Fechas
     </h5>

           <div class="alert alert-info border-0" style="background: linear-gradient(135deg, rgba(8,137,255,0.1) 0%, rgba(8,207,255,0.1) 100%); border-left: 4px solid var(--color-2);">
       <i class="fas fa-info-circle color2"></i>
               <strong>Duraciůn del prťstamo:</strong>
   <ul class="mb-0 mt-2">
   <li>Estudiante: 14 dŪas</li>
      <li>Docente: 30 dŪas</li>
         </ul>
        </div>

         <div class="d-grid gap-2 mt-4">
         <button type="submit" class="btn btn-primary btn-lg">
   <i class="fas fa-save"></i> Registrar Prťstamo
</button>
         <a asp-action="Index" class="btn btn-outline-secondary">
         <i class="fas fa-times"></i> Cancelar
            </a>
         </div>
    </form>
        </div>
        </div>
    </div>
</div>

@section Scripts {
 @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
