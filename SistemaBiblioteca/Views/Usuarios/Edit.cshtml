@model SistemaBiblioteca.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow">
  <div class="card-header bg-color2 text-white">
             <h3 class="mb-0">
<i class="fas fa-user-edit"></i> Editar Usuario
          </h3>
      </div>
<div class="card-body p-4">
     <form asp-action="Edit" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="IdUsuario" />

      <!-- Información Personal -->
              <h5 class="color1 mb-3">
     <i class="fas fa-user color2"></i> Información Personal
      </h5>

         <div class="row g-3 mb-3">
            <div class="col-md-6">
   <label asp-for="Nombres" class="form-label fw-semibold color2">Nombres *</label>
                 <input asp-for="Nombres" class="form-control" required>
   <span asp-validation-for="Nombres" class="text-danger small"></span>
    </div>
   <div class="col-md-6">
  <label asp-for="Apellidos" class="form-label fw-semibold color2">Apellidos *</label>
         <input asp-for="Apellidos" class="form-control" required>
            <span asp-validation-for="Apellidos" class="text-danger small"></span>
     </div>
             </div>

           <div class="row g-3 mb-3">
    <div class="col-md-4">
          <label asp-for="DNI" class="form-label fw-semibold color2">DNI *</label>
          <input asp-for="DNI" class="form-control" required>
 <span asp-validation-for="DNI" class="text-danger small"></span>
       </div>
   <div class="col-md-4">
     <label asp-for="Telefono" class="form-label fw-semibold color2">Teléfono</label>
                <input asp-for="Telefono" class="form-control">
     </div>
        <div class="col-md-4">
        <label asp-for="Correo" class="form-label fw-semibold color2">Correo *</label>
     <input asp-for="Correo" type="email" class="form-control" required>
              <span asp-validation-for="Correo" class="text-danger small"></span>
       </div>
      </div>

                <div class="mb-3">
   <label asp-for="Direccion" class="form-label fw-semibold color2">Dirección</label>
                <input asp-for="Direccion" class="form-control">
  </div>

        <hr class="my-4">

    <!-- Configuración de Rol -->
          <h5 class="color1 mb-3">
  <i class="fas fa-shield-alt color2"></i> Configuración de Rol
   </h5>

           <div class="row g-3 mb-3">
         <div class="col-md-6">
        <label asp-for="IdRol" class="form-label fw-semibold color2">Rol *</label>
<select asp-for="IdRol" class="form-select" required>
      <option value="">-- Seleccione --</option>
          @foreach (var rol in ViewBag.Roles as List<SistemaBiblioteca.Models.Rol>)
       {
  <option value="@rol.IdRol">@rol.NombreRol</option>
             }
     </select>
      </div>
     <div class="col-md-6">
         <label class="form-label fw-semibold color2">Estado</label>
         <div class="form-check mt-2">
      <input asp-for="Activo" type="checkbox" class="form-check-input" id="activo">
      <label class="form-check-label color1" for="activo">
           Usuario Activo
                </label>
  </div>
        </div>
         </div>

           <hr class="my-4">

           <!-- Cambio de Contraseńa -->
              <h5 class="color1 mb-3">
          <i class="fas fa-lock color2"></i> Cambio de Contraseńa (Opcional)
       </h5>

      <div class="alert alert-info border-0" style="background: linear-gradient(135deg, rgba(8,137,255,0.1) 0%, rgba(8,207,255,0.1) 100%); border-left: 4px solid var(--color-2);">
      <i class="fas fa-info-circle color2"></i> Deja en blanco si no deseas cambiar la contraseńa
       </div>

        <div class="row g-3 mb-4">
          <div class="col-md-6">
     <label class="form-label fw-semibold color2">Nueva Contraseńa</label>
                <input name="nuevaContrasena" type="password" class="form-control" placeholder="••••••••">
            <small class="text-muted">Mínimo 6 caracteres</small>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold color2">Confirmar Contraseńa</label>
        <input name="confirmarContrasena" type="password" class="form-control" placeholder="••••••••">
    </div>
             </div>

     <!-- Información Adicional (Solo lectura) -->
  <hr class="my-4">

                <h5 class="color1 mb-3">
    <i class="fas fa-info-circle color2"></i> Información del Sistema
     </h5>

        <div class="row g-3">
         <div class="col-md-6">
   <small class="text-muted d-block">Fecha de Registro</small>
          <strong class="color1">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</strong>
            </div>
     <div class="col-md-6">
    <small class="text-muted d-block">Último Acceso</small>
       <strong class="color1">@(Model.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</strong>
      </div>
     </div>

      <hr class="my-4">

       <!-- Botones de Acción -->
          <div class="d-grid gap-2">
     <button type="submit" class="btn btn-primary btn-lg">
           <i class="fas fa-save"></i> Guardar Cambios
     </button>
         <a asp-action="Index" class="btn btn-outline-secondary">
    <i class="fas fa-times"></i> Cancelar
   </a>
            </div>
           </form>
            </div>
   </div>
    </div>
</div>

@section Scripts {
  @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
     // Validar que las contraseńas coincidan
     document.querySelector('form').addEventListener('submit', function (e) {
        const nuevaContrasena = document.querySelector('input[name="nuevaContrasena"]').value;
     const confirmarContrasena = document.querySelector('input[name="confirmarContrasena"]').value;

  // Si hay contraseńa nueva, validar que coincida
      if (nuevaContrasena && nuevaContrasena !== confirmarContrasena) {
    e.preventDefault();
        alert('Las contraseńas no coinciden');
      document.querySelector('input[name="confirmarContrasena"]').focus();
          }

            // Si hay una contraseńa pero no la otra
    if ((nuevaContrasena && !confirmarContrasena) || (!nuevaContrasena && confirmarContrasena)) {
        e.preventDefault();
   alert('Debes ingresar ambas contraseńas o dejar ambas en blanco');
    return false;
         }
        });
    </script>
}
