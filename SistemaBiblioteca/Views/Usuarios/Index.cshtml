@model IEnumerable<SistemaBiblioteca.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="fw-bold color1">
            <i class="fas fa-users color3"></i> Gestión de Usuarios
        </h2>
        <p class="color2">Administra todos los usuarios del sistema</p>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-user-plus"></i> Nuevo Usuario
        </a>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-5">
                <label class="form-label fw-semibold color2">Buscar</label>
                <input type="text" name="buscar" class="form-control"
                       placeholder="Nombre, DNI o correo..." value="@ViewBag.Buscar">
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold color2">Rol</label>
                <select name="rolFiltro" class="form-select">
                    <option value="">Todos los roles</option>
                    @foreach (var rol in ViewBag.Roles as List<SistemaBiblioteca.Models.Rol>)
                    {
                        <option value="@rol.IdRol">@rol.NombreRol</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search"></i> Buscar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Tabla de Usuarios -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="bg-color2 text-white">
                    <tr>
                        <th><i class="fas fa-hashtag"></i> ID</th>
                        <th><i class="fas fa-user"></i> Nombre Completo</th>
                        <th><i class="fas fa-id-card"></i> DNI</th>
                        <th><i class="fas fa-envelope"></i> Correo</th>
                        <th><i class="fas fa-user-tag"></i> Rol</th>
                        <th><i class="fas fa-calendar"></i> Registro</th>
                        <th><i class="fas fa-toggle-on"></i> Estado</th>
                        <th class="text-center"><i class="fas fa-cogs"></i> Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var usuario in Model)
                        {
                            <tr>
                                <td>@usuario.IdUsuario</td>
                                <td>
                                    <strong class="color1">@usuario.NombreCompleto</strong>
                                </td>
                                <td>@usuario.DNI</td>
                                <td>
                                    <small class="color2">@usuario.Correo</small>
                                </td>
                                <td>
                                    <span class="badge bg-color3">@usuario.Rol.NombreRol</span>
                                </td>
                                <td>
                                    <small class="color1">@usuario.FechaRegistro.ToString("dd/MM/yyyy")</small>
                                </td>
                                <td>
                                    @if (usuario.Activo)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="fas fa-times"></i> Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@usuario.IdUsuario"
                                           class="btn btn-info" title="Ver detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@usuario.IdUsuario"
                                           class="btn btn-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-danger"
                                                onclick="eliminarUsuario(@usuario.IdUsuario, '@usuario.NombreCompleto')"
                                                title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="fas fa-users fa-3x color2 mb-3"></i>
                                <p class="color2">No se encontraron usuarios</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function eliminarUsuario(id, nombre) {
            if (confirm(`¿Está seguro de eliminar al usuario "${nombre}"?`)) {
                $.ajax({
                    url: '@Url.Action("Delete", "Usuarios")/' + id,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('Error al eliminar el usuario');
                    }
                });
            }
        }
    </script>

    @Html.AntiForgeryToken()
}